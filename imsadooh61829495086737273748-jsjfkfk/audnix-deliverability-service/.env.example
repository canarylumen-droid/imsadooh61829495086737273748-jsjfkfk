# Server
PORT=3100
NODE_ENV=production

# Database (Postgres)
DATABASE_URL=postgresql://postgres:password@helium/heliumdb?sslmode=disable

# Warmup service — the only upstream dependency
WARMUP_SERVICE_URL=http://localhost:3001
WARMUP_API_KEY=

# Core webhook — where placement/reputation alerts are sent
CORE_WEBHOOK_URL=http://localhost:5000/api/webhooks/deliverability
CORE_WEBHOOK_SECRET=

# Google Postmaster Tools (optional — leave blank to skip)
POSTMASTER_API_KEY=
POSTMASTER_CLIENT_ID=
POSTMASTER_CLIENT_SECRET=
POSTMASTER_REFRESH_TOKEN=

# Microsoft SNDS (optional — leave blank to skip)
SNDSS_CLIENT_ID=
SNDSS_CLIENT_SECRET=
SNDSS_TENANT_ID=

# Polling intervals (ms or cron expressions)
SEED_POLL_INTERVAL=*/10 * * * *
POSTMASTER_POLL_INTERVAL=0 6 * * *
SNDS_POLL_INTERVAL=0 7 * * *

# Seed placement thresholds
INBOX_RATE_WARN=0.85
INBOX_RATE_PAUSE=0.70
POSTMASTER_SPAM_RATE_WARN=0.003
