{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx --import ./instrument.ts server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.json",
    "build:workers": "npm run build:server",
    "db:migrate": "node scripts/migrate-manual.js",
    "db:push": "drizzle-kit push",
    "db:push:force": "drizzle-kit push --force",
    "db:patch-target-url": "tsx scripts/patch-target-url.ts",
    "setup": "npx tsx scripts/setup.ts",
    "verify": "npx tsx scripts/verify-setup.ts",
    "check": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc --noEmit",
    "start": "node --import tsx --import ./instrument.ts server/index.ts",
    "start:api": "node --import tsx --import ./instrument.ts services/api-gateway/index.ts",
    "start:worker:email": "node --import tsx --import ./instrument.ts services/email-service/index.ts",
    "start:worker:outreach": "node --import tsx --import ./instrument.ts services/outreach-worker/index.ts",
    "start:worker:rag": "node --import tsx --import ./instrument.ts services/rag-worker/index.ts",
    "start:worker:vectordb": "node --import tsx --import ./instrument.ts services/vector-db-service/index.ts",
    "start:all": "concurrently \"npm run start:api\" \"npm run start:all-workers\"",
    "start:all-workers": "concurrently \"npm run start:worker:email\" \"npm run start:worker:outreach\" \"npm run:worker:rag\" \"npm run start:worker:vectordb\""
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "csurf": "^1.11.0",
    "drizzle-orm": "^0.45.2",
    "express-rate-limit": "^8.5.2",
    "fast-xml-parser": "^5.8.0",
    "helmet": "^8.1.0",
    "lodash": "^4.18.1",
    "minimatch": "^10.2.5",
    "rollup": "^4.60.4",
    "serialize-javascript": "^7.0.5",
    "socket.io": "^4.8.3",
    "undici": "^8.3.0",
    "vite": "^8.0.14"
  }
}
