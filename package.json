{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx --import ./instrument.ts server/index.ts",
    "test:connections": "tsx test-connections.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc -p tsconfig.json",
    "build:workers": "npm run build:server",
    "db:migrate": "cross-env IS_WORKER=false node scripts/migrate-manual.js",
    "db:migrate:direct": "cross-env IS_WORKER=false NODE_ENV=production node scripts/migrate-manual.js",
    "db:push": "cross-env IS_WORKER=false drizzle-kit push",
    "db:push:direct": "cross-env IS_WORKER=false NODE_ENV=production drizzle-kit push",
    "db:push:force": "cross-env IS_WORKER=false drizzle-kit push --force",
    "db:generate": "cross-env IS_WORKER=false drizzle-kit generate",
    "db:patch-target-url": "tsx scripts/patch-target-url.ts",
    "setup": "npx tsx scripts/setup.ts",
    "db:reset": "npx tsx scripts/reset-db.ts",
    "verify": "npx tsx scripts/verify-setup.ts",
    "check": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "npm run start:api-gateway",
    "start:api": "npm run start:api-gateway",
    "start:unified": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/api-gateway/index.ts",
    "start:api-gateway": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/api-gateway/api-only.ts",
    "start:socket": "npm run start:socket-server",
    "start:socket-server": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/socket-service/index.ts",
    "start:worker:email": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/email-service/index.ts",
    "start:worker:imap": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/email-worker/src/index.ts",
    "start:worker:ai": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/brain-worker/index.ts",
    "start:worker:outreach": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/outreach-worker/index.ts",
    "start:worker:lead-recovery": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/lead-recovery-worker/index.ts",
    "start:worker:social": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/social-worker/src/social/index.ts",
    "start:worker:billing": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/billing-service/src/billing/index.ts",
    "start:worker:orchestrator": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/brain-worker/src/orchestrator/index.ts",
    "start:worker:knowledge": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/rag-worker/index.ts",
    "start:worker:audit": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts shared/services/audit/index.ts",
    "start:worker:rag": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/rag-worker/index.ts",
    "start:worker:vectordb": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/vector-db-service/index.ts",
    "start:worker:warmup": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/warmup-service/index.ts",
    "start:infra:scaler": "node --require ./polyfill-file.cjs --import tsx --import ./instrument.ts services/outreach-worker/src/outreach-lib/infra-scaler-entry.ts",
    "start:all": "concurrently \"npm run start:api\" \"npm run start:all-workers\"",
    "start:all-workers": "concurrently \"npm run start:worker:email\" \"npm run start:worker:imap\" \"npm run start:worker:ai\" \"npm run start:worker:outreach\" \"npm run start:worker:lead-recovery\" \"npm run start:worker:social\" \"npm run start:worker:billing\" \"npm run start:worker:orchestrator\" \"npm run start:worker:knowledge\" \"npm run start:worker:audit\" \"npm run start:worker:warmup\" \"npm run start:infra:scaler\"",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "start:pm2:production": "pm2 start ecosystem.config.cjs --env production",
    "stop:pm2": "pm2 stop ecosystem.config.cjs",
    "restart:pm2": "pm2 restart ecosystem.config.cjs",
    "deploy": "bash deploy.sh",
    "delete:pm2": "pm2 delete ecosystem.config.cjs",
    "logs:pm2": "pm2 logs",
    "monit:pm2": "pm2 monit"
  },
  "engines": {
    "node": "22.x"
  },
