# =============================================================================
# Audnix AI — AWS Production Environment Variables
# =============================================================================
# 1. Copy:  cp .env.aws.example .env
# 2. Fill in ALL values marked ⚠️  REQUIRED — app will not start without them
# 3. Fill in optional values to enable those features
# 4. DO NOT commit .env to git — it contains secrets!
# =============================================================================

# =============================================================================
# CORE — REQUIRED
# =============================================================================

NODE_ENV=production
PORT=5000
# Your public domain (used for OAuth callbacks, email tracking links, webhooks)
# ⚠️  REQUIRED — set this before OAuth works
APP_URL=https://your-domain.com

# =============================================================================
# DATABASE — REQUIRED
# =============================================================================

# Neon PostgreSQL — https://console.neon.tech → your project → Connection String
# ⚠️  REQUIRED
DATABASE_URL=postgresql://user:password@neon-host.neon.tech/audnix?sslmode=require

# =============================================================================
# REDIS (EXTERNAL) — REQUIRED
# =============================================================================
# Redis handles BullMQ job queues, real-time pub/sub, rate limiting & sessions.
# Use an external managed Redis service — do NOT leave this blank.
#
# Option 1: Upstash (RECOMMENDED — free tier: 10K commands/day)
#   1. https://console.upstash.com → Create Database
#   2. Region: same as your EC2 (e.g. us-east-1)
#   3. Details tab → Connect → Node.js section → copy the rediss:// URL
#   Format:  rediss://default:PASSWORD@HOST.upstash.io:6380
#
# Option 2: Redis Cloud (free tier: 30MB)
#   https://redis.io/try-free → Create database → copy Public Endpoint
#   Format:  redis://default:PASSWORD@HOST.redns.redis-cloud.com:PORT
#
# ⚠️  Upstash requires rediss:// (double-s = TLS). Redis Cloud supports both.
# ⚠️  REQUIRED
REDIS_URL=rediss://default:your-redis-password@your-host.upstash.io:6380

# Redis tuning (optional — defaults shown, used by redis-config.ts)
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=10000
REDIS_RECONNECT_MAX_RETRIES=100

# =============================================================================
# AUTH & SECURITY — REQUIRED
# =============================================================================

# Generate with:  openssl rand -hex 32   (must be ≥ 32 chars)
# ⚠️  REQUIRED
SESSION_SECRET=change-this-to-a-64-character-random-hex-string

# Generate with:  openssl rand -hex 16   (must be exactly 32 chars)
# ⚠️  REQUIRED
ENCRYPTION_KEY=change-this-to-a-32-character-random-hex-string

# Admin secret path for the hidden admin dashboard URL
# ⚠️  REQUIRED — set to something random (e.g. openssl rand -hex 8)
VITE_ADMIN_SECRET_URL=your-secret-admin-path

# Admin API key for running migrations via API (x-admin-key header)
# ⚠️  REQUIRED in production
ADMIN_SECRET_KEY=your-admin-secret-key

# Comma-separated admin email addresses
# ⚠️  REQUIRED — at least one email for admin access
ADMIN_WHITELIST_EMAILS=admin@your-domain.com

# =============================================================================
# AI PROVIDERS
# =============================================================================

# OpenAI — https://platform.openai.com/api-keys
# ⚠️  REQUIRED (primary AI provider)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Z-AI (GLM — Chinese AI, OpenAI-compatible) — optional alternative AI
# NOTE: both ZAI_API_KEY and Z_AI_API_KEY are read by different files — set both
ZAI_API_KEY=your-zai-key
Z_AI_API_KEY=your-zai-key

# ElevenLabs Voice AI — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Fathom AI (meeting intelligence) — https://app.fathom.video/settings/api
FATHOM_API_KEY=your-fathom-api-key

# Super Memory API — https://supermemory.ai
SUPER_MEMORY_API_KEY=your-super-memory-api-key

# =============================================================================
# EMAIL — REQUIRED
# =============================================================================

# SendGrid — https://app.sendgrid.com/settings/api_keys
# ⚠️  NOTE: variable MUST be named TWILIO_SENDGRID_API_KEY (code reads this exact name)
# ⚠️  REQUIRED for OTP, password reset, all transactional emails
TWILIO_SENDGRID_API_KEY=SG.your-sendgrid-key

# From address for transactional emails (OTP, auth emails)
# ⚠️  REQUIRED — must be a verified sender in your SendGrid account
TWILIO_EMAIL_FROM=noreply@your-domain.com

# Resend (fallback email provider) — https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-key

# System SMTP (optional — for internal alert/notification emails)
SYSTEM_SMTP_HOST=smtp.your-provider.com
SYSTEM_SMTP_PORT=465
SYSTEM_SMTP_USER=your-smtp-user
SYSTEM_SMTP_PASS=your-smtp-password

# Twilio SMS (optional — for OTP via SMS)
TWILIO_SID=AC_your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1234567890

# =============================================================================
# STRIPE (PAYMENTS) — REQUIRED
# =============================================================================

# https://dashboard.stripe.com/apikeys
# ⚠️  REQUIRED
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# Stripe webhook secret — https://dashboard.stripe.com/webhooks
# ⚠️  REQUIRED for subscription events
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Price IDs for plan mapping in webhook handler
# ⚠️  REQUIRED — without these, webhooks won't map subscriptions to the right plan
# Get from: https://dashboard.stripe.com/products
STRIPE_STARTER_PRICE_ID=price_your-starter-price-id
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_ENTERPRISE_PRICE_ID=price_your-enterprise-price-id

# =============================================================================
# OAUTH: GOOGLE (Gmail + Calendar) — REQUIRED for Gmail/Calendar features
# =============================================================================

# https://console.cloud.google.com/apis/credentials → Create OAuth 2.0 Client
# Authorized redirect URI: https://your-domain.com/api/oauth/gmail/callback
# ⚠️  Both pairs are read (GMAIL_ takes priority, GOOGLE_ is fallback)
GMAIL_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-client-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Cloud project (for Gmail push notifications via Pub/Sub — optional)
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_PUBSUB_TOPIC=projects/your-google-project-id/topics/audnix-gmail-push

# =============================================================================
# OAUTH: MICROSOFT OUTLOOK — REQUIRED for Outlook/Calendar features
# =============================================================================

# https://portal.azure.com → App registrations
# Redirect URI: https://your-domain.com/api/oauth/outlook/callback
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
# Set to your tenant ID, or leave as 'common' to allow any Microsoft account
OUTLOOK_TENANT_ID=common

# =============================================================================
# OAUTH: META / INSTAGRAM — REQUIRED for Instagram DM features
# =============================================================================

# https://developers.facebook.com/apps → your app → Basic Settings
# ⚠️  NOTE: variable MUST be META_APP_ID / META_APP_SECRET (code reads these exact names)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Redirect URI for Instagram OAuth — must match exactly in Meta App settings
# Set to: https://your-domain.com/api/oauth/instagram/callback
META_REDIRECT_URI=https://your-domain.com/api/oauth/instagram/callback

# Webhook verify token — set in Meta App Dashboard → Webhooks → Verify Token
# Choose any random string and paste the same value in the Meta dashboard
META_VERIFY_TOKEN=your-meta-webhook-verify-token

# =============================================================================
# OAUTH: CALENDLY
# =============================================================================

# https://calendly.com/integrations/api_webhooks
CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret
CALENDLY_WEBHOOK_SECRET=your-calendly-webhook-secret

# =============================================================================
# STORAGE: AWS S3 — REQUIRED for file uploads
# =============================================================================

# https://console.aws.amazon.com/iam → Users → your user → Security credentials
# ⚠️  NOTE: variable MUST be S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY (code reads these exact names)
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
S3_BUCKET_NAME=your-s3-bucket-name
S3_REGION=us-east-1
# S3_ENDPOINT=  # Only needed for Cloudflare R2 or custom S3-compatible storage

# =============================================================================
# MONITORING
# =============================================================================

# Sentry error tracking — https://sentry.io
# ⚠️  NOTE: variable MUST be OBSERVABILITY_SENTRY_DSN (code reads this exact name)
OBSERVABILITY_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/project-id

# Log level: error | warn | info | debug
LOG_LEVEL=info

# =============================================================================
# PUSH NOTIFICATIONS (VAPID)
# =============================================================================

# Generate with:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
# Or: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# =============================================================================
# UNIFIED WORKER MODE (DO NOT CHANGE — set by docker-compose)
# =============================================================================

UNIFIED_MODE=true
AI_WORKER_PORT=8082
EMAIL_WORKER_PORT=8081
OUTREACH_WORKER_PORT=8083
BILLING_WORKER_PORT=8085
LEAD_RECOVERY_WORKER_PORT=8095
