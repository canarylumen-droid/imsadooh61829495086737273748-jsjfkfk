# ====== SECRET ADMIN DASHBOARD URL ======
VITE_ADMIN_SECRET_URL=admin-secret-xyz

# Database (Vercel PostgreSQL / Neon / Railway)
DATABASE_URL=postgresql://user:password@host/database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/audnix?retryWrites=true&w=majority
MONGO_URL=
REDIS_URL=rediss://default:password@your-private-redis-endpoint:6379
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_TLS=true
REDIS_PRIVATE_ENDPOINT_REQUIRED=true
REDIS_PRIVATE_HOST_SUFFIXES=.internal,.private,privatelink,private-link,railway.internal
REDIS_ALLOW_PUBLIC_ENDPOINT=false
REDIS_CLOUD_HA_ENABLED=true
REDIS_CLOUD_AOF_ENABLED=true
REDIS_LATENCY_P99_SLO_MS=15
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=10000
REDIS_RECONNECT_MAX_RETRIES=100

# Queue-depth autoscaling
QUEUE_AUTOSCALER_ENABLED=false
QUEUE_AUTOSCALER_POLL_MS=15000
QUEUE_AUTOSCALER_COOLDOWN_MS=180000
QUEUE_AUTOSCALER_MIN_REPLICAS=1
QUEUE_AUTOSCALER_MAX_REPLICAS=10
QUEUE_AUTOSCALER_SCALE_UP_AT=100
QUEUE_AUTOSCALER_SCALE_DOWN_AT=20
RAILWAY_SCALE_WEBHOOK_TOKEN=
RAILWAY_SCALE_WEBHOOK_AI=
RAILWAY_SCALE_WEBHOOK_SOCIAL=
RAILWAY_SCALE_WEBHOOK_BILLING=
RAILWAY_SCALE_WEBHOOK_ORCHESTRATOR=
RAILWAY_SCALE_WEBHOOK_KNOWLEDGE=
RAILWAY_SCALE_WEBHOOK_AUDIT=
RAILWAY_SCALE_WEBHOOK_EMAIL=
RAILWAY_SCALE_WEBHOOK_IMAP=
RAILWAY_SCALE_WEBHOOK_OUTREACH=
RAILWAY_SCALE_WEBHOOK_LEAD_RECOVERY=
RAILWAY_SCALE_WEBHOOK_VECTOR_DB=

# Session & Security
SESSION_SECRET=your-secure-session-secret-here
ENCRYPTION_KEY=your-encryption-key-here
ADMIN_SECRET_KEY=
ADMIN_WHITELIST_EMAILS=admin@audnixai.com

# AI API Keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=your-gemini-api-key-here
Z_AI_API_KEY=your-z-ai-api-key-here
DEEPSEEK_API_KEY=sk-...
FATHOM_API_KEY=your-fathom-api-key-here
