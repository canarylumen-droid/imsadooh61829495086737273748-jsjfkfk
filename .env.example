# =============================================================================
# Audnix AI — Environment Variables
# =============================================================================
# This file documents ALL env vars used across local dev, Railway, and AWS ECS.
# For ECS: store secrets in AWS Secrets Manager, not here.
# =============================================================================

# ====== SECRET ADMIN DASHBOARD URL ======
VITE_ADMIN_SECRET_URL=admin-secret-xyz

# ====== DATABASE & CACHE ======
# Neon / Railway / AWS RDS — SSL required for cloud providers
# POOL = Transaction Pooler (port 6543 on Neon). Used by app/workers.
# DIRECT = Direct connection (port 5432 on Neon). Used ONLY for migrations/DDL.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:password@host/database?sslmode=require

# Redis — Upstash / ElastiCache / Redis Cloud (TLS recommended)
REDIS_URL=rediss://default:password@your-redis-endpoint:6379
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=true
REDIS_LATENCY_P99_SLO_MS=15
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=10000
REDIS_RECONNECT_MAX_RETRIES=100

# ====== ECS / FARGATE SPECIFIC ======
# These are set automatically by the ECS task definition or Dockerfile.ecs.
# You do NOT need to set them in .env for ECS — they are documented here for clarity.
#
# APP_ROLE determines which service boots inside the container:
#   api | socket | email | imap | outreach | brain | social | billing | rag | vectordb | lead-recovery
# APP_ROLE=api
#
# PORT=5000                           # All ECS services use port 5000 (isolated containers)
# UNIFIED_MODE=false                  # ECS runs split services, not unified mode
# IS_WORKER=true                      # true = worker pod (higher DB pool), false = API/migration pod
# ECS_ENABLE_CONTAINER_METADATA=true # Enables ECS metadata endpoint (needed for task ID discovery)
#
# DB pool sizing for Fargate workers (prevents connection exhaustion)
# DB_POOL_MAX_WORKER=100
# DB_POOL_MAX_API=20
# DB_POOL_ABSOLUTE_CAP=120

# ====== RAILWAY SPECIFIC (skip for ECS) ======
# Railway uses these webhooks for queue-based autoscaling. Not needed on AWS.
QUEUE_AUTOSCALER_ENABLED=false
QUEUE_AUTOSCALER_POLL_MS=15000
QUEUE_AUTOSCALER_COOLDOWN_MS=180000
QUEUE_AUTOSCALER_MIN_REPLICAS=1
QUEUE_AUTOSCALER_MAX_REPLICAS=10
QUEUE_AUTOSCALER_SCALE_UP_AT=100
QUEUE_AUTOSCALER_SCALE_DOWN_AT=20
RAILWAY_SCALE_WEBHOOK_TOKEN=
RAILWAY_SCALE_WEBHOOK_AI=
RAILWAY_SCALE_WEBHOOK_SOCIAL=
RAILWAY_SCALE_WEBHOOK_BILLING=
RAILWAY_SCALE_WEBHOOK_ORCHESTRATOR=
RAILWAY_SCALE_WEBHOOK_KNOWLEDGE=
RAILWAY_SCALE_WEBHOOK_AUDIT=
RAILWAY_SCALE_WEBHOOK_EMAIL=
RAILWAY_SCALE_WEBHOOK_IMAP=
RAILWAY_SCALE_WEBHOOK_OUTREACH=
RAILWAY_SCALE_WEBHOOK_LEAD_RECOVERY=
RAILWAY_SCALE_WEBHOOK_VECTOR_DB=

# ====== EMAIL BACKEND ======
# Primary: Rust Email Sender (default). Set to "node" to force NodeMailer fallback.
# KumoMTA is INACTIVE — do not use. Users provide their own SMTP/IMAP credentials.
NEW_EMAIL_BACKEND=rust
RUST_EMAIL_SENDER_PATH=/usr/local/bin/audnix-email-sender
RUST_IMAP_WORKER_PATH=/usr/local/bin/audnix-imap-worker

# ====== SESSION & SECURITY ======
SESSION_SECRET=change-this-to-a-64-char-random-string-minimum-length-required
ENCRYPTION_KEY=change-this-to-a-32-char-random-string-for-aes-256
ADMIN_SECRET_KEY=
ADMIN_WHITELIST_EMAILS=admin@audnixai.com

# ====== AI API KEYS ======
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=your-gemini-api-key-here
Z_AI_API_KEY=your-z-ai-api-key-here
DEEPSEEK_API_KEY=sk-...
FATHOM_API_KEY=your-fathom-api-key-here
ELEVENLABS_API_KEY=
SUPER_MEMORY_API_KEY=

# ====== LEAD RECOVERY ======
LEAD_RECOVERY_WORKER_POLL_MS=300000
LEAD_RECOVERY_RESYNC_INTERVAL_MS=86400000
LEAD_RECOVERY_MAX_MESSAGES_PER_MAILBOX=500
LEAD_RECOVERY_SYSTEM_PROMPT="You are the Audnix email lead recovery agent. Analyze inbound email history and return strict JSON only."
LEAD_RECOVERY_USER_PROMPT_TEMPLATE="Analyze this lead recovery conversation. This is not a normal outreach campaign and must not reuse a generic initial campaign sequence. Source mailbox: {{mailbox}} Conversation summary: {{conversationSummary}} From: {{from}} Subject: {{subject}} Date: {{date}} Last message: {{lastMessage}} Full body: {{body}} Return JSON with intent as one of Converted, Ghosted, Not-Interested, Reply-Needed, followUpDraft that replies from the same mailbox and matches exactly where the conversation stopped, and brainstormedObjections as an array of {category, rule, evidence}."

# ====== STRIPE BILLING ======
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ====== LEMONSQUEEZY BILLING ======
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STARTER_VARIANT_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_ENTERPRISE_VARIANT_ID=

# ====== GOOGLE OAUTH (GMAIL / CALENDAR / WORKSPACE) ======
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_PUBSUB_TOPIC=

# ====== MICROSOFT OUTLOOK OAUTH ======
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common

# ====== META / INSTAGRAM OAUTH ======
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
META_VERIFY_TOKEN=

# ====== CALENDLY OAUTH ======
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_WEBHOOK_SECRET=

# ====== TWILIO / SENDGRID (EMAIL OTP) ======
TWILIO_SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
TWILIO_EMAIL_FROM=noreply@audnixai.com
SYSTEM_SMTP_HOST=
SYSTEM_SMTP_USER=
SYSTEM_SMTP_PASS=
SYSTEM_SMTP_PORT=465

# ====== OBJECT STORAGE (CLOUDFLARE R2 / AWS S3) ======
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_ENDPOINT=

# ====== PUSH NOTIFICATIONS (VAPID) ======
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ====== MONITORING ======
OBSERVABILITY_SENTRY_DSN=
LOG_LEVEL=info

# ====== BULLMQ WORKER CONCURRENCY (tune for 1M+ scale) ======
CAMPAIGN_CONCURRENCY=50
CAMPAIGN_LOCK_DURATION_MS=120000
CAMPAIGN_STALLED_INTERVAL_MS=300000
CAMPAIGN_MAX_STALLED_COUNT=3
CAMPAIGN_RATE_MAX=15
FATHOM_CONCURRENCY=5
CALENDLY_CONCURRENCY=10
BILLING_CONCURRENCY=5

# ====== APP CONFIG ======
DOMAIN=audnixai.com
APP_URL=https://audnixai.com
NEXT_PUBLIC_APP_URL=https://audnixai.com
NODE_ENV=production

# ====== PORT CONFIGURATION ======
# For LOCAL DEV / RAILWAY: each service gets its own port.
# For AWS ECS: ignore these. Every service uses PORT=5000 (set in Dockerfile.ecs).
# The fallback chain in code is: XXX_WORKER_PORT -> PORT -> default.
PORT=5000
AI_WORKER_PORT=8082
EMAIL_WORKER_PORT=8081
OUTREACH_WORKER_PORT=8083
BILLING_WORKER_PORT=8085
SOCIAL_WORKER_PORT=8084
RAG_WORKER_PORT=8089
VECTOR_DB_WORKER_PORT=8092
LEAD_RECOVERY_WORKER_PORT=8095
SOCKET_PORT=8087

# ====== IMAP PERFORMANCE (used by imap-worker) ======
IMAP_DYNAMIC_SHARDING=true
IMAP_MAX_SOCKETS=50

# ====== WARMUP SERVICE (Platform Seeds) ======
# Enable platform-owned seeds for cross-provider warmup
# WARMUP_PLATFORM_SEEDS=true

# JSON array of seed accounts — Audnix-owned Gmail/Outlook accounts used ONLY for warmup.
# NEVER used for campaigns. Stored in warmup_seed_accounts table (separate from user integrations).
# Each seed handles max 10 partner domains and 400 sends/day.
# WARMUP_SEEDS=[{"email":"warmup1@gmail.com","smtpPass":"your-gmail-app-password","provider":"gmail"},{"email":"warmup2@outlook.com","smtpPass":"your-outlook-password","provider":"outlook"}]

# Warmup volume limits (per mailbox per day)
# WARMUP_DAILY_SENT_LIMIT=20
# WARMUP_DAILY_RECEIVED_LIMIT=20

# Anchors per domain (2 = one Gmail + one Outlook ideal)
# WARMUP_ANCHORS_PER_DOMAIN=2

# Max member mailboxes per anchor (50 members : 1 Gmail seed)
# WARMUP_MAX_MEMBERS_PER_ANCHOR=50

# Seed daily limit before rotation
# WARMUP_SEED_DAILY_LIMIT=400
# WARMUP_SEED_MAX_PARTNERS=10

# ====== PER-PROVIDER CAMPAIGN LIMITS ======
# When sending campaigns, each provider (Google, Microsoft, Yahoo, Other)
# gets its own reputation score and daily limit based on bounce/spam rates.
# If Yahoo leads bounce → only Yahoo limit drops, Gmail limit stays high.
# Data stored in integrations.provider_limits JSONB.
# Automatically calculated by services/email-service/src/email/provider-reputation.ts
# To reset per-provider limits for an integration:
#   UPDATE integrations SET provider_limits = '{}'::jsonb WHERE id = '<integration_id>';

# ====== WARMUP SEED PROVISIONING EXAMPLES ======
# Gmail seed (use App Password from Google Account > Security > 2FA > App Passwords):
# {"email":"warmup1@gmail.com","smtpPass":"xxxx yyyy zzzz aaaa","provider":"gmail"}
#
# Outlook seed (use Microsoft account password or app password):
# {"email":"warmup2@outlook.com","smtpPass":"your-password","provider":"outlook"}
#
# Multi-seed config:
# WARMUP_SEEDS=[
#   {"email":"seed.g1@gmail.com","smtpPass":"aaaa bbbb cccc dddd","provider":"gmail"},
#   {"email":"seed.g2@gmail.com","smtpPass":"eeee ffff gggg hhhh","provider":"gmail"},
#   {"email":"seed.o1@outlook.com","smtpPass":"password123","provider":"outlook"},
#   {"email":"seed.o2@outlook.com","smtpPass":"password456","provider":"outlook"}
# ]
#
# Recommended: 50/50 split of Gmail + Outlook seeds for best cross-provider warmup.
# Minimum viable: all Gmail (still works, just less cross-provider diversity bonus).
# For 1000 custom mailboxes → 20 seeds (10 Gmail + 10 Outlook) at ~$120/mo.
# Enable platform seeds for warmup
WARMUP_PLATFORM_SEEDS=true

# JSON array of seed accounts (Single-line format recommended for .env parsing compatibility)
WARMUP_SEEDS='[{"email":"seed1@gmail.com","smtpPass":"xxxx yyyy zzzz aaaa","provider":"gmail"},{"email":"seed2@outlook.com","smtpPass":"your-password","provider":"outlook"}]'

# ====== PAYMENT PROCESSORS ======

# Stripe — Live keys (production)
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe — Test keys (development)
# STRIPE_SECRET_KEY=sk_test_your_test_key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key

# Flutterwave — Live keys (production, Africa-focused payments)
# Get these from https://dashboard.flutterwave.com/settings/keys
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-your_public_key
FLUTTERWAVE_SECRET_KEY=FLWSECK-your_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=your_encryption_key
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_hash
# Set to "1" to enable Flutterwave (for African payment regions)
FLUTTERWAVE_ENABLED=false

# ====== DELIVERABILITY SERVICE (standalone microservice) ======
# Runs as its own PM2 process: pm2 start services/deliverability-service/ecosystem.config.js
# Checks inbox placement via IMAP, polls Google Postmaster & Microsoft SNDS
# Reads the root .env like the other services. services/deliverability-service/.env is optional for local overrides.
#
# Shared internal auth for service-to-service calls. Required in production.
# INTERNAL_API_KEY=change-this-to-a-random-string

# Warmup service internal API (for fetching seed account credentials)
# WARMUP_INTERNAL_PORT=3101
# WARMUP_SERVICE_URL=http://localhost:3101
# WARMUP_API_KEY=change-this-to-a-random-string

# Core webhook — deliverability service POSTs placement alerts here
# The main backend must handle POST /api/webhooks/deliverability
# CORE_WEBHOOK_URL=http://localhost:5000/api/webhooks/deliverability
# CORE_WEBHOOK_SECRET=change-this-to-a-random-string
# DELIVERABILITY_WEBHOOK_URL=http://localhost:5000/api/webhooks/deliverability
# DELIVERABILITY_WEBHOOK_SECRET=change-this-to-a-random-string

# Google Postmaster Tools (optional — leave blank to skip daily polling)
# POSTMASTER_API_KEY=
# POSTMASTER_CLIENT_ID=
# POSTMASTER_CLIENT_SECRET=
# POSTMASTER_REFRESH_TOKEN=

# Microsoft SNDS (optional — leave blank to skip daily polling)
# SNDS_CLIENT_ID=
# SNDS_CLIENT_SECRET=
# SNDS_TENANT_ID=
# Legacy aliases still supported:
# SNDSS_CLIENT_ID=
# SNDSS_CLIENT_SECRET=
# SNDSS_TENANT_ID=

# Inbox placement thresholds (defaults shown)
# INBOX_RATE_WARN=0.85          # Below 85% → webhook with action: "warn"
# INBOX_RATE_PAUSE=0.70         # Below 70% → webhook with action: "pause"
# POSTMASTER_SPAM_RATE_WARN=0.003  # Above 0.3% spam rate → warn

# Polling intervals (cron expressions)
# SEED_POLL_INTERVAL=*/10 * * * *    # Every 10 minutes
# POSTMASTER_POLL_INTERVAL=0 6 * * * # Daily at 6am
# SNDS_POLL_INTERVAL=0 7 * * *       # Daily at 7am

# ====== QUICK START — MINIMAL .env FOR LOCAL DEV ======
# Copy this to .env and fill in the marked values:
#
# DATABASE_URL=postgresql://postgres:password@helium/heliumdb?sslmode=disable
# SESSION_SECRET=dev-session-secret-change-in-production-min-64-chars
# ENCRYPTION_KEY=dev-encryption-key-change-me-32-chars!!
# APP_URL=http://localhost:5000
# DOMAIN=localhost
# NODE_ENV=development
# PORT=5000
#
# # At minimum, one AI key for email generation:
# OPENAI_API_KEY=sk-your-key-here
#
# # For email sending (pick one):
# # Option A: Custom SMTP
# SYSTEM_SMTP_HOST=smtp.gmail.com
# SYSTEM_SMTP_USER=you@gmail.com
# SYSTEM_SMTP_PASS=your-app-password
# SYSTEM_SMTP_PORT=465
# # Option B: Gmail OAuth (set in UI, not .env)
#
# # For billing (optional, leave blank for free tier):
# # STRIPE_SECRET_KEY=sk_test_...
# # NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
