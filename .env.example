# Lead Recovery (Email-only, MongoDB-backed)
LEAD_RECOVERY_WORKER_POLL_MS=300000
LEAD_RECOVERY_RESYNC_INTERVAL_MS=86400000
LEAD_RECOVERY_MAX_MESSAGES_PER_MAILBOX=500
LEAD_RECOVERY_SYSTEM_PROMPT="You are the Audnix email lead recovery agent. Analyze inbound email history and return strict JSON only."
LEAD_RECOVERY_USER_PROMPT_TEMPLATE="Analyze this lead recovery conversation. This is not a normal outreach campaign and must not reuse a generic initial campaign sequence. Source mailbox: {{mailbox}} Conversation summary: {{conversationSummary}} From: {{from}} Subject: {{subject}} Date: {{date}} Last message: {{lastMessage}} Full body: {{body}} Return JSON with intent as one of Converted, Ghosted, Not-Interested, Reply-Needed, followUpDraft that replies from the same mailbox and matches exactly where the conversation stopped, and brainstormedObjections as an array of {category, rule, evidence}."

